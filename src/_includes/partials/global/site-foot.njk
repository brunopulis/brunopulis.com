<footer class="[ site-foot ] [ pad-top-700 pad-bottom-900 ]">
  <div class="wrapper">
    <div class="[ site-foot__inner ] [ md:box-flex space-between align-start ]">
      {% if site.shortDesc %}
        <div>
          <article class="[ site-foot__details ] [ sf-flow measure-compact ]">
            <h2 class="font-base text-600">{{ site.name }}</h2>
            {{ site.shortDesc | markdownFilter | safe }}
            <a
              href="https://www.accessibilityassociation.org/s/"
              class="[ pad-top-300 ]"
              rel="noopener noreferrer"
              style="display:block;"
              target="_blank">
              <img src="/images/iaap-member.png" alt="International Association of Accessibility Professionals" width="345"/>
            </a>
          </article>
        </div>
      {% endif %}
      <div>
        {% set ariaLabel = 'Navegação do rodapé' %}
        {% include "partials/components/nav.njk" %}
        <theme-toggle></theme-toggle>
      </div>
    </div>
    {% if site.showThemeCredit %}
      <p class="[ site-foot__credit ] [ pad-top-900 ]">
        Feito com 
        <a href="https://hylia.website" rel="external">Hylia Eleventy Starter Kit v{{ pkg.version }}</a> e <span aria-label="amor">❤️</span>.
      </p>
    {% endif %}
  </div>
</footer>
